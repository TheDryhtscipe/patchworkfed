%% Patchwork Federation — meeting process
flowchart TB

  subgraph MEETING["At the meeting"]
    direction TB
    M(["Member"]) -->|submits motion<br/>in advance| AGENDA["Standing orders<br/><i>compile agenda</i>"]
    AGENDA --> SENSE{{"Sense vote<br/><i>federation floor threshold</i>"}}
    SENSE -->|passes| S1["Step 1<br/>Informal Consent"]
    SENSE -.->|fails| DROP["Drops off agenda"]
    S1 -->|objection| S2["Step 2<br/>Formal Consent<br/><i>dedicated session</i>"]
    S2 -->|deadlock| S3["Step 3<br/>Ballot"]
    S1 -->|passes| OUT(["Decision"])
    S2 -->|consent reached| OUT
    S3 --> OUT
  end

  subgraph WG_CYCLE["Working Group cycle"]
    direction TB
    COMM["Patch Committee<br/>chair · secretary · treasurer<br/><b>majority lay</b>"] -->|creates on consent| WG["Working Group<br/><i>time-limited remit</i>"]
    WG -->|reports back| COMM
    COMM -.->|renew or close| WG
  end

  OUT -.creates WG via.-> COMM

  classDef accent fill:#f0ebe3,stroke:#8b2500,stroke-width:2px,color:#1a1a1a
  classDef body fill:#f8f6f1,stroke:#1a1a1a,stroke-width:1.5px,color:#1a1a1a
  classDef process fill:#fff,stroke:#8b2500,stroke-width:1.5px,color:#1a1a1a,stroke-dasharray: 3 3
  classDef muted fill:#f8f6f1,stroke:#d4cfc8,stroke-width:1px,color:#6b6560,stroke-dasharray: 2 2
  class COMM accent
  class WG,M,AGENDA,OUT body
  class S1,S2,S3 process
  class DROP muted
