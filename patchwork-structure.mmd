%% Patchwork Federation — structure
flowchart TB
  MEMBERS(["Membership"])

  subgraph CONSTRAINTS[" "]
    direction TB
    KERNEL["Ethical Kernel<br/><i>raise-only floor</i>"]
    PRACTICES["Common Practices<br/>democracy · safeguarding · legal"]
  end

  subgraph PATCHES["Patches"]
    direction LR
    P1["Patch A"]
    P2["Patch B"]
    P3["Patch …"]
    P1 <-.->|transient merger<br/>for dispute| P2
  end

  subgraph SECTIONS["Sections"]
    direction LR
    SX["Section<br/><i>self-governing</i>"]
  end

  CONGRESS["Permanent Congress<br/><i>ongoing deliberation</i><br/>slow · fast tracks"]

  subgraph NATIONAL["National Bodies"]
    direction TB
    FAC["Federation Action Committee<br/><i>patch at federation scale</i>"]
    NATPATCH["Other National Patches<br/><i>voluntary</i>"]
  end

  CONF["Conference<br/><i>annual or distributed</i><br/>40% Congress · 30% patches · 30% sections"]
  RES["Resolutions<br/><i>independent track</i>"]

  MEMBERS -->|form| PATCHES
  MEMBERS -->|form| SECTIONS
  MEMBERS -->|participate in| CONGRESS
  MEMBERS -->|elects at conference<br/>+ recall petition| FAC
  MEMBERS -.->|sortition pool| RES

  CONSTRAINTS ==>|gate affiliation| PATCHES

  PATCHES -->|motions| CONGRESS
  SECTIONS -->|motions| CONGRESS
  CONGRESS ==>|dissolves into| CONF

  PATCHES -->|mandated, recallable<br/>delegates| NATIONAL
  PATCHES -->|delegates| CONF
  SECTIONS -->|delegates| CONF

  PATCHES ==>|safeguarding or<br/>kernel violation| RES
  SECTIONS ==>|safeguarding or<br/>kernel violation| RES

  CONF -->|mandates strategy| FAC
  CONF -.->|may raise| KERNEL
  RES -.-> KERNEL

  classDef kernel fill:#1a1a1a,color:#f8f6f1,stroke:#1a1a1a,stroke-width:2px
  classDef accent fill:#f0ebe3,stroke:#8b2500,stroke-width:2px,color:#1a1a1a
  classDef body fill:#f8f6f1,stroke:#1a1a1a,stroke-width:1.5px,color:#1a1a1a
  class KERNEL kernel
  class PRACTICES,FAC,RES,CONGRESS accent
  class NATPATCH,P1,P2,P3,SX,CONF,MEMBERS body
